generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- User (linked to Clerk) ---

model User {
  id        String   @id @default(cuid())
  clerkId   String?  @unique  // Optional - only for creators using Clerk
  email     String   @unique
  name      String?
  role      Role     @default(LEARNER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Creator onboarding fields
  bio                String?  @db.Text
  niche              String?
  outcomeTarget      String?  @db.Text
  onboardingComplete Boolean  @default(false)

  // Stripe Connect fields (for creators)
  stripeAccountId       String?  @unique  // Stripe Connect account ID
  stripeAccountStatus   String?  // "pending", "active", "restricted"
  stripeOnboardingComplete Boolean @default(false)

  programs            Program[]
  entitlements        Entitlement[]
  progress            LearnerProgress[]
  followedInfluencers UserInfluencer[]
  magicLinks          MagicLink[]
}

// --- Magic Link for Learner Authentication ---

model MagicLink {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId String?  // Optional: link to specific program for context
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

enum Role {
  CREATOR
  LEARNER
  ADMIN
}

// --- Program ---

model Program {
  id               String      @id @default(cuid())
  title            String
  slug             String      @unique
  description      String?
  outcomeStatement String?     @db.Text
  durationWeeks    Int
  pacingMode       PacingMode  @default(DRIP_BY_WEEK)
  priceInCents     Int         @default(0)
  currency         String      @default("usd")
  published        Boolean     @default(false)
  status           ProgramStatus @default(DRAFT)  // Deprecated: use `published` instead. Remove in next migration.
  stripeProductId  String?
  stripePriceId    String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  // Enhanced program definition fields
  targetAudience       String?   @db.Text  // "Who it's for" / industry
  targetTransformation String?   @db.Text  // 1-2 sentence transformation goal
  vibePrompt           String?   @db.Text  // AI generation style guidance
  skinId               String    @default("default")

  creatorId     String
  creator       User        @relation(fields: [creatorId], references: [id])

  weeks            Week[]
  videos           YouTubeVideo[]
  drafts           ProgramDraft[]
  entitlements     Entitlement[]
  embeddings       Embedding[]
  clusters         ClusterAssignment[]
  cohorts          Cohort[]
  artifacts        ProgramArtifact[]
  rating           ProgramRating?
  generationJobs   GenerationJob[]
  styleInfluencers String[]  // Array of influencer IDs that influenced this program
}

enum PacingMode {
  DRIP_BY_WEEK        // Weekly release: content unlocks on a time-based schedule
  UNLOCK_ON_COMPLETE  // Staged: next session/week unlocks after completing the current one
}

enum ProgramStatus {
  DRAFT
  PUBLISHED
}

enum DurationPreset {
  SIX_WEEKS    // 6
  EIGHT_WEEKS  // 8
  TWELVE_WEEKS // 12
}

// --- Week / Session / Action ---

model Week {
  id         String   @id @default(cuid())
  title      String
  summary    String?
  weekNumber Int
  programId  String
  program    Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  sessions   Session[]

  @@unique([programId, weekNumber])
}

model Session {
  id           String   @id @default(cuid())
  title        String
  summary      String?
  orderIndex   Int
  weekId       String
  week         Week     @relation(fields: [weekId], references: [id], onDelete: Cascade)
  actions      Action[]
  keyTakeaways String[] // 2-3 key takeaway bullets per session

  compositeSession CompositeSession?
}

model Action {
  id               String     @id @default(cuid())
  title            String
  type             ActionType
  instructions     String?
  reflectionPrompt String?
  orderIndex       Int
  sessionId        String
  session          Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  youtubeVideoId   String?
  youtubeVideo     YouTubeVideo? @relation(fields: [youtubeVideoId], references: [id])

  progress         LearnerProgress[]
}

enum ActionType {
  WATCH
  READ
  DO
  REFLECT
}

// --- Composite Session (multi-clip playlist for a session) ---

enum TransitionType {
  NONE
  FADE
  CROSSFADE
  SLIDE_LEFT
}

enum OverlayType {
  TITLE_CARD
  CHAPTER_TITLE
  KEY_POINTS
  LOWER_THIRD
  CTA
  OUTRO
}

enum OverlayPosition {
  CENTER
  BOTTOM
  TOP
  LOWER_THIRD
}

model CompositeSession {
  id            String   @id @default(cuid())
  sessionId     String   @unique
  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title         String?
  description   String?
  thumbnailUrl  String?
  autoAdvance   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clips    SessionClip[]
  overlays SessionOverlay[]
}

model SessionClip {
  id                   String         @id @default(cuid())
  compositeSessionId   String
  compositeSession     CompositeSession @relation(fields: [compositeSessionId], references: [id], onDelete: Cascade)
  youtubeVideoId       String
  youtubeVideo         YouTubeVideo   @relation(fields: [youtubeVideoId], references: [id])
  startSeconds         Float?
  endSeconds           Float?
  orderIndex           Int
  transitionType       TransitionType @default(NONE)
  transitionDurationMs Int            @default(500)
  chapterTitle         String?
  chapterDescription   String?

  @@unique([compositeSessionId, orderIndex])
}

model SessionOverlay {
  id                 String          @id @default(cuid())
  compositeSessionId String
  compositeSession   CompositeSession @relation(fields: [compositeSessionId], references: [id], onDelete: Cascade)
  type               OverlayType
  content            Json
  clipOrderIndex     Int?
  triggerAtSeconds   Float?
  durationMs         Int             @default(5000)
  position           OverlayPosition @default(CENTER)
  orderIndex         Int
}

// --- YouTube Video ---

model YouTubeVideo {
  id              String   @id @default(cuid())
  videoId         String   // YouTube video ID
  url             String
  title           String?
  authorName      String?
  thumbnailUrl    String?
  description     String?
  durationSeconds Int?     // Video duration in seconds
  transcript      String?  @db.Text  // Auto-fetched captions/transcript
  programId       String
  program         Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  actions       Action[]
  embeddings    Embedding[]
  clips         SessionClip[]

  @@unique([programId, videoId])
}

// --- Program Draft (AI-generated, pending approval) ---

model ProgramDraft {
  id         String   @id @default(cuid())
  programId  String
  program    Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  draftJson  Json     // Full ProgramDraft schema as JSON
  status     DraftStatus @default(PENDING)
  createdAt  DateTime @default(now())
}

enum DraftStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// --- Entitlement (purchase/enrollment) ---

model Entitlement {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  programId           String
  program             Program  @relation(fields: [programId], references: [id])
  stripeSessionId     String?  @unique
  stripePaymentIntent String?
  status              EntitlementStatus @default(ACTIVE)
  currentWeek         Int      @default(1)  // Which week the learner has access to
  createdAt           DateTime @default(now())

  weekCompletions     WeekCompletion[]

  @@unique([userId, programId])
}

// --- Week Completion Tracking ---

model WeekCompletion {
  id            String   @id @default(cuid())
  entitlementId String
  entitlement   Entitlement @relation(fields: [entitlementId], references: [id], onDelete: Cascade)
  weekNumber    Int
  completedAt   DateTime @default(now())

  @@unique([entitlementId, weekNumber])
}

enum EntitlementStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

// --- Learner Progress ---

model LearnerProgress {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  actionId       String
  action         Action    @relation(fields: [actionId], references: [id])
  completed      Boolean   @default(false)
  completedAt    DateTime?
  reflectionText String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, actionId])
}

// --- AI: Embeddings ---

model Embedding {
  id         String   @id @default(cuid())
  programId  String
  program    Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  videoId    String
  video      YouTubeVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)
  model      String   // e.g. "sentence-transformers/all-MiniLM-L6-v2"
  vector     Json     // float[] stored as JSONB (use pgvector extension for production scale)
  createdAt  DateTime @default(now())

  @@unique([programId, videoId, model])
}

// --- AI: Cluster Assignments ---

model ClusterAssignment {
  id         String   @id @default(cuid())
  programId  String
  program    Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  videoId    String
  clusterId  Int
  createdAt  DateTime @default(now())

  @@unique([programId, videoId])
}

// --- Future: Cohort (stub, no UI wired) ---

model Cohort {
  id         String   @id @default(cuid())
  programId  String
  program    Program  @relation(fields: [programId], references: [id])
  name       String
  startDate  DateTime
  endDate    DateTime?
  createdAt  DateTime @default(now())
}

// --- Influencer for Style Matching ---

model Influencer {
  id              String   @id @default(cuid())
  name            String
  platform        String   // "youtube", "instagram", etc.
  platformHandle  String   // @username or channel ID
  avatarUrl       String?
  niche           String?
  styleProfile    Json?    // AI-generated style characteristics
  sampleVideoIds  String[] // YouTube video IDs analyzed for style
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  followers       UserInfluencer[]

  @@unique([platform, platformHandle])
}

// --- User-Influencer Follow Relationship ---

model UserInfluencer {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  influencerId String
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([userId, influencerId])
}

// --- Program Artifact (metadata only - no file storage) ---

model ProgramArtifact {
  id               String   @id @default(cuid())
  programId        String
  program          Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  originalFilename String
  fileType         String   // "pdf", "docx"
  extractedText    String?  @db.Text
  metadata         Json?    // { pageCount, wordCount, etc. }
  createdAt        DateTime @default(now())
}

// --- Future: Program Rating (stub for now) ---

model ProgramRating {
  id                String    @id @default(cuid())
  programId         String    @unique
  program           Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  uniquenessScore   Float?    // 0-100 (future AI evaluation)
  completenessScore Float?    // 0-100 (future AI evaluation)
  evaluatedAt       DateTime?
  createdAt         DateTime  @default(now())
}

// --- Async Generation Job ---

model GenerationJob {
  id            String          @id @default(cuid())
  programId     String
  program       Program         @relation(fields: [programId], references: [id], onDelete: Cascade)
  status        GenerationStatus @default(PENDING)
  stage         String?         // "embedding", "clustering", "generating", "persisting"
  progress      Int             @default(0)  // 0-100
  error         String?         @db.Text
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime        @default(now())

  @@index([programId])
  @@index([status])
}

enum GenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
